generator client {
  provider = "prisma-client-js"
  output   = "../../node_modules/.prisma/website-client"
}

datasource db {
  provider = "postgresql"
}

enum PermissionLevel {
  READ
  WRITE
  ADMIN
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

// ════════════════════════════════════════════
// USERS
// ════════════════════════════════════════════

model User {
  token     String   @id @default(uuid())
  accountId String?  @map("account_id")
  username  String   @unique
  firstName String?  @map("first_name")
  lastName  String?  @map("last_name")
  imgLink   String   @default("") @map("img_link")
  mail      String   @unique
  passwd    String
  createdAt DateTime @default(now()) @map("created_at")

  ownedTags          Tag[]          @relation("TagOwner")
  ownedPages         Page[]         @relation("PageOwner")
  ownedOrganizations Organization[] @relation("OrganizationOwner")

  tagMemberships  TagMember[]
  tagPermissions  TagPermission[]
  pagePermissions PagePermission[]
  orgMemberships  OrganizationMember[]

  tagPageRequestsMade     TagPageRequest[] @relation("RequestedBy")
  tagPageRequestsReviewed TagPageRequest[] @relation("ReviewedBy")

  @@map("users")
}

// ════════════════════════════════════════════
// TAGS
// ════════════════════════════════════════════

model Tag {
  id          Int      @id @default(autoincrement())
  ownerToken  String   @map("owner_token")
  name        String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  owner       User            @relation("TagOwner", fields: [ownerToken], references: [token])
  roles       TagRole[]
  members     TagMember[]
  permissions TagPermission[]

  tagPages          TagPage[]
  tagPageRequests   TagPageRequest[]
  tagPageAccess     TagPageAccess[]
  tagPageCapability TagPageCapability[]

  orgTagAccess     OrgTagAccess[]
  orgTagCapability OrgTagCapability[]

  @@map("tags")
}

model TagRole {
  id             Int    @id @default(autoincrement())
  tagId          Int    @map("tag_id")
  roleName       String @map("role_name")
  hierarchyLevel Int    @map("hierarchy_level")

  canManageMembers    Boolean @default(false) @map("can_manage_members")
  canManageRoles      Boolean @default(false) @map("can_manage_roles")
  canEditInfo         Boolean @default(false) @map("can_edit_info")
  canDeleteTag        Boolean @default(false) @map("can_delete_tag")
  canAddPage          Boolean @default(false) @map("can_add_page")
  canRevokePage       Boolean @default(false) @map("can_revoke_page")
  canManagePageGrants Boolean @default(false) @map("can_manage_page_grants")
  canReviewRequests   Boolean @default(false) @map("can_review_requests")

  tag     Tag         @relation(fields: [tagId], references: [id], onDelete: Cascade)
  members TagMember[]

  minRoleForPageAccess       TagPageAccess[]
  exactRoleForPageCapability TagPageCapability[]

  @@unique([tagId, hierarchyLevel])
  @@map("tag_roles")
}

model TagMember {
  tagId     Int    @map("tag_id")
  userToken String @map("user_token")
  roleId    Int    @map("role_id")

  tag  Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)
  user User    @relation(fields: [userToken], references: [token], onDelete: Cascade)
  role TagRole @relation(fields: [roleId], references: [id])

  @@id([tagId, userToken])
  @@map("tag_members")
}

// Direct Permission of a user to a tag
model TagPermission {
  tagId     Int    @map("tag_id")
  userToken String @map("user_token")

  canManageMembers    Boolean @default(false) @map("can_manage_members")
  canManageRoles      Boolean @default(false) @map("can_manage_roles")
  canEditInfo         Boolean @default(false) @map("can_edit_info")
  canDeleteTag        Boolean @default(false) @map("can_delete_tag")
  canAddPage          Boolean @default(false) @map("can_add_page")
  canRevokePage       Boolean @default(false) @map("can_revoke_page")
  canManagePageGrants Boolean @default(false) @map("can_manage_page_grants")
  canReviewRequests   Boolean @default(false) @map("can_review_requests")

  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userToken], references: [token], onDelete: Cascade)

  @@id([tagId, userToken])
  @@map("tag_permissions")
}

// ════════════════════════════════════════════
// PAGES
// ════════════════════════════════════════════

model Page {
  pageId       Int      @id @default(autoincrement()) @map("page_id")
  title        String
  content      Json?
  ownerId      String   @map("owner_id")
  createdAt    DateTime @default(now()) @map("created_at")
  lastModified DateTime @updatedAt @map("last_modified")

  owner User @relation("PageOwner", fields: [ownerId], references: [token])

  permissions PagePermission[]
  tagPages    TagPage[]

  tagPageRequests   TagPageRequest[]
  tagPageAccess     TagPageAccess[]
  tagPageCapability TagPageCapability[]

  orgPageAccess     OrgPageAccess[]
  orgPageCapability OrgPageCapability[]

  @@map("pages")
}

// Direct Permission access of a user to a Page
model PagePermission {
  pageId    Int    @map("page_id")
  userToken String @map("user_token")

  permissions PermissionLevel // read/write/admin

  canManagePermissions Boolean @default(false) @map("can_manage_permissions")
  canManageTags        Boolean @default(false) @map("can_manage_tags")
  canRequestTags       Boolean @default(false) @map("can_request_tags")

  page Page @relation(fields: [pageId], references: [pageId], onDelete: Cascade)
  user User @relation(fields: [userToken], references: [token], onDelete: Cascade)

  @@id([pageId, userToken])
  @@map("page_permissions")
}

model TagPage {
  tagId  Int @map("tag_id")
  pageId Int @map("page_id")

  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)
  page Page @relation(fields: [pageId], references: [pageId], onDelete: Cascade)

  @@id([tagId, pageId])
  @@map("tag_pages")
}

model TagPageRequest {
  id          Int           @id @default(autoincrement())
  tagId       Int           @map("tag_id")
  pageId      Int           @map("page_id")
  requestedBy String        @map("requested_by")
  status      RequestStatus @default(PENDING)
  reviewedBy  String?       @map("reviewed_by")
  createdAt   DateTime      @default(now()) @map("created_at")

  tag       Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)
  page      Page  @relation(fields: [pageId], references: [pageId], onDelete: Cascade)
  requester User  @relation("RequestedBy", fields: [requestedBy], references: [token])
  reviewer  User? @relation("ReviewedBy", fields: [reviewedBy], references: [token])

  @@map("tag_page_requests")
}

model TagPageAccess {
  pageId      Int             @map("page_id")
  tagId       Int             @map("tag_id")
  minRoleId   Int             @map("min_role_id")
  permissions PermissionLevel

  page    Page    @relation(fields: [pageId], references: [pageId], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)
  minRole TagRole @relation(fields: [minRoleId], references: [id])

  @@id([pageId, tagId])
  @@map("tag_page_access")
}

model OrgPageAccess {
  orgId       Int             @map("org_id")
  pageId      Int             @map("page_id")
  minRoleId   Int             @map("min_role_id")
  permissions PermissionLevel

  organization Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  page         Page             @relation(fields: [pageId], references: [pageId], onDelete: Cascade)
  minRole      OrganizationRole @relation(fields: [minRoleId], references: [id])

  @@id([orgId, pageId])
  @@map("org_page_access")
}

model TagPageCapability {
  pageId Int @map("page_id")
  tagId  Int @map("tag_id")
  roleId Int @map("role_id")

  canManagePermissions Boolean @default(false) @map("can_manage_permissions")
  canManageTags        Boolean @default(false) @map("can_manage_tags")
  canRequestTags       Boolean @default(false) @map("can_request_tags")

  page Page    @relation(fields: [pageId], references: [pageId], onDelete: Cascade)
  tag  Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)
  role TagRole @relation(fields: [roleId], references: [id])

  @@id([pageId, tagId, roleId])
  @@map("tag_page_capability")
}

model OrgPageCapability {
  orgId  Int @map("org_id")
  pageId Int @map("page_id")
  roleId Int @map("role_id")

  canManagePermissions Boolean @default(false) @map("can_manage_permissions")
  canManageTags        Boolean @default(false) @map("can_manage_tags")
  canRequestTags       Boolean @default(false) @map("can_request_tags")

  organization Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  page         Page             @relation(fields: [pageId], references: [pageId], onDelete: Cascade)
  role         OrganizationRole @relation(fields: [roleId], references: [id])

  @@id([orgId, pageId, roleId])
  @@map("org_page_capability")
}

// ════════════════════════════════════════════
// ORGANISATIONS
// ════════════════════════════════════════════

model Organization {
  id         Int      @id @default(autoincrement())
  ownerToken String   @map("owner_token")
  name       String   @unique
  createdAt  DateTime @default(now()) @map("created_at")

  owner   User                 @relation("OrganizationOwner", fields: [ownerToken], references: [token])
  roles   OrganizationRole[]
  members OrganizationMember[]

  orgPageAccess     OrgPageAccess[]
  orgPageCapability OrgPageCapability[]
  orgTagAccess      OrgTagAccess[]
  orgTagCapability  OrgTagCapability[]

  @@map("organizations")
}

model OrganizationRole {
  id             Int    @id @default(autoincrement())
  organizationId Int    @map("organization_id")
  roleName       String @map("role_name")
  hierarchyLevel Int    @map("hierarchy_level")

  canManageMembers       Boolean @default(false) @map("can_manage_members")
  canManageRoles         Boolean @default(false) @map("can_manage_roles")
  canEditInfo            Boolean @default(false) @map("can_edit_info")
  canDeleteOrg           Boolean @default(false) @map("can_delete_org")
  canManageOrgPageGrants Boolean @default(false) @map("can_manage_org_page_grants")
  canManageOrgTagGrants  Boolean @default(false) @map("can_manage_org_tag_grants")

  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members      OrganizationMember[]

  minRoleForOrgPageAccess  OrgPageAccess[]
  roleForOrgPageCapability OrgPageCapability[]
  minRoleForOrgTagAccess   OrgTagAccess[]
  roleForOrgTagCapability  OrgTagCapability[]

  @@unique([organizationId, hierarchyLevel])
  @@map("organization_roles")
}

model OrganizationMember {
  organizationId Int    @map("organization_id")
  userToken      String @map("user_token")
  roleId         Int    @map("role_id")

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User             @relation(fields: [userToken], references: [token], onDelete: Cascade)
  role         OrganizationRole @relation(fields: [roleId], references: [id])

  @@id([organizationId, userToken])
  @@map("organization_members")
}

model OrgTagAccess {
  orgId       Int             @map("org_id")
  tagId       Int             @map("tag_id")
  minRoleId   Int             @map("min_role_id")
  permissions PermissionLevel

  organization Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  tag          Tag              @relation(fields: [tagId], references: [id], onDelete: Cascade)
  minRole      OrganizationRole @relation(fields: [minRoleId], references: [id])

  @@id([orgId, tagId])
  @@map("org_tag_access")
}

model OrgTagCapability {
  orgId  Int @map("org_id")
  tagId  Int @map("tag_id")
  roleId Int @map("role_id")

  canManageTagMembers Boolean @default(false) @map("can_manage_tag_members")
  canManageTagRoles   Boolean @default(false) @map("can_manage_tag_roles")
  canAddPage          Boolean @default(false) @map("can_add_page")
  canRevokePage       Boolean @default(false) @map("can_revoke_page")
  canManagePageGrants Boolean @default(false) @map("can_manage_page_grants")
  canReviewRequests   Boolean @default(false) @map("can_review_requests")

  organization Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  tag          Tag              @relation(fields: [tagId], references: [id], onDelete: Cascade)
  role         OrganizationRole @relation(fields: [roleId], references: [id])

  @@id([orgId, tagId, roleId])
  @@map("org_tag_capability")
}
